{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "双 AI 多轮执行器",
  "version": "0.1.0",
  "identifier": "com.chat-to-chat.publish-single",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "双 AI 多轮执行器",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
